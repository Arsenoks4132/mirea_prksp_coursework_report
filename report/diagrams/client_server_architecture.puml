@startuml
left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam rectangle {
  BorderColor black
  BackgroundColor white
}
skinparam database {
  BorderColor black
  BackgroundColor white
}
skinparam actor {
  BorderColor black
  BackgroundColor white
}

actor "Пользователь\n(браузер)" as Browser

rectangle "Уровень балансировки" {
  rectangle "Traefik\n(балансировщик\nнагрузки)" as Traefik
}

rectangle "Уровень веб-сервера" {
  rectangle "Nginx × 3\n(статика / медиа /\nпроксирование)" as Nginx
}

rectangle "Уровень сервера приложений" {
  rectangle "Gunicorn\n(WSGI)" as Gunicorn
  rectangle "Django\n(URL Router →\nViews → ORM →\nTemplates)" as Django
}

rectangle "Уровень хранения данных" {
  database "PostgreSQL\n(основная БД)" as PG
  database "Redis\n(кэш страниц)" as Redis
}

Browser --> Traefik : HTTP-запрос\n(порт 80)
Traefik --> Nginx : статические запросы
Traefik --> Gunicorn : динамические запросы
Nginx --> Gunicorn : проксирование
Gunicorn --> Django : WSGI вызов
Django --> PG : SQL через ORM
Django --> Redis : кэш GET/SET
Django --> Browser : HTML-ответ\n(через Nginx → Traefik)

@enduml
