@startuml
left to right direction
skinparam backgroundColor white
skinparam shadowing false
skinparam usecase {
  BorderColor black
  BackgroundColor white
  ArrowColor black
}
skinparam actor {
  BorderColor black
  BackgroundColor white
}

actor "Сотрудник" as Employee
actor "Руководитель" as Supervisor
actor "Администратор" as Admin

rectangle "TaskAndTimes" {
  usecase "Зарегистрироваться" as UC1
  usecase "Войти в систему" as UC2
  usecase "Просмотреть профиль" as UC3
  usecase "Добавить задачу" as UC4
  usecase "Редактировать задачу" as UC5
  usecase "Удалить задачу" as UC6
  usecase "Редактировать профиль" as UC7
  usecase "Сменить пароль" as UC8
  usecase "Выйти из системы" as UC9
  usecase "Просмотреть статистику\nсотрудников" as UC10
  usecase "Просмотреть задачи\nсотрудника" as UC11
  usecase "Редактировать задачу\nлюбого сотрудника" as UC12
  usecase "Управлять категориями" as UC13
  usecase "Управлять\nпользователями" as UC14
  usecase "Управлять всеми\nданными системы" as UC15
}

Employee --> UC1
Employee --> UC2
Employee --> UC3
Employee --> UC4
Employee --> UC5
Employee --> UC6
Employee --> UC7
Employee --> UC8
Employee --> UC9

Supervisor --> UC2
Supervisor --> UC9
Supervisor --> UC10
Supervisor --> UC11
Supervisor --> UC12
Supervisor --> UC13

Admin --> UC14
Admin --> UC15

@enduml
